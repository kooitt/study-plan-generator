rules_version = '2';

// NOTE ON EMAILS
// --------------
// `request.auth.token.email` is used directly (without `.lower()`) because
// Firestore's static query-safety analyzer rejects list queries whose rule
// condition contains computed values. Google Sign-in always returns gmail
// addresses in all-lowercase, and the client normalises any invited email
// to lowercase before writing it into `memberEmails`, so the two values
// align. Do not re-introduce `.lower()` here or the `plans` list query
// will be denied with "Missing or insufficient permissions".

service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------
    // plans/{planId}
    //   ownerUid:      string   UID of creator
    //   ownerEmail:    string   email of creator (lowercased by client)
    //   name:          string   display name
    //   memberEmails:  list     lowercased emails allowed to read/write
    //   state:         map      app state (subjects, slots, dates, options)
    //   done:          map      { "subjectId::topicId": true, ... }
    //   createdAt:     timestamp
    //   updatedAt:     timestamp
    // ------------------------------------------------------------------
    match /plans/{planId} {

      // READ (get + list): signed-in user's email must be on the plan.
      allow read: if request.auth != null
                  && request.auth.token.email != null
                  && request.auth.token.email in resource.data.memberEmails;

      // CREATE: the creator must be signed in, must be the owner, must include
      // themselves in memberEmails, and must use a reasonable name.
      allow create: if request.auth != null
                    && request.auth.token.email != null
                    && request.resource.data.ownerUid   == request.auth.uid
                    && request.resource.data.ownerEmail == request.auth.token.email
                    && request.resource.data.memberEmails is list
                    && request.auth.token.email in request.resource.data.memberEmails
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 120;

      // UPDATE:
      //   - any current member may edit `state`, `done`, `updatedAt`, `name`
      //   - only the owner may change `memberEmails`, `ownerUid`, `ownerEmail`
      allow update: if request.auth != null
                    && request.auth.token.email != null
                    && request.auth.token.email in resource.data.memberEmails
                    && (
                      request.auth.uid == resource.data.ownerUid ||
                      (
                        request.resource.data.ownerUid     == resource.data.ownerUid &&
                        request.resource.data.ownerEmail   == resource.data.ownerEmail &&
                        request.resource.data.memberEmails == resource.data.memberEmails
                      )
                    );

      // DELETE: owner only.
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerUid;
    }

    // ------------------------------------------------------------------
    // users/{uid} — optional per-user profile (active plan, etc.)
    // ------------------------------------------------------------------
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
